## 💻 2. O Código Fonte (Go)

### A. Modelos (Mapeamento do JSON)

Arquivo: `internal/models/template.go`

```go
package models

type Template struct {
	TemplateID string   `json:"template_id"`
	Resolution Size     `json:"resolution"`
	FPS        int      `json:"fps"`
	Cards      []Card   `json:"cards"`
}

type Size struct {
	Width  int `json:"width"`
	Height int `json:"height"`
}

type Card struct {
	ID              string    `json:"id"`
	DurationMs      int       `json:"duration_ms"`
	BackgroundColor string    `json:"background_color"`
	Elements        []Element `json:"elements"`
}

type Element struct {
	Type     string `json:"type"` // "text", "image"
	Content  string `json:"content,omitempty"`
	FontSize float64 `json:"font_size,omitempty"`
	Color    string `json:"color,omitempty"`
	X        float64 `json:"x"`
	Y        float64 `json:"y"`
}

```

### B. O Desenhista (Renderização em Memória)

Arquivo: `internal/engine/renderer.go`

Usa a biblioteca gráfica `gg` para desenhar pixels sem navegador, e "injeta" via pipe no FFmpeg para virar um arquivo de vídeo rápido `.ts` (MPEG-TS é ideal para juntar partes sem perda).

```go
package engine

import (
	"fmt"
	"image/png"
	"os/exec"
	"videogen/internal/models"
	"github.com/fogleman/gg"
)

// RenderCard processa um card específico e gera um arquivo .ts temporário
func RenderCard(card models.Card, res models.Size, fps int, outPath string) error {
	totalFrames := (card.DurationMs / 1000) * fps

	// Comando FFmpeg esperando imagens no Stdin (Pipe)
	cmd := exec.Command("ffmpeg", 
		"-y", 
		"-f", "image2pipe", 
		"-vcodec", "png", 
		"-r", fmt.Sprintf("%d", fps), 
		"-i", "-", 
		"-c:v", "libx264", 
		"-pix_fmt", "yuv420p", 
		outPath,
	)

	stdin, err := cmd.StdinPipe()
	if err != nil {
		return err
	}
	
	if err := cmd.Start(); err != nil {
		return err
	}

	// Loop desenhando os frames na RAM
	for f := 0; f < totalFrames; f++ {
		dc := gg.NewContext(res.Width, res.Height)
		
		// Fundo
		dc.SetHexColor(card.BackgroundColor)
		dc.Clear()

		// Desenhar elementos (simplificado)
		for _, el := range card.Elements {
			if el.Type == "text" {
				dc.SetHexColor(el.Color)
				// NOTA: No código real, carregue a fonte ttf aqui com dc.LoadFontFace()
				dc.DrawStringAnchored(el.Content, el.X, el.Y, 0.5, 0.5)
			}
		}

		// Envia a imagem pro FFmpeg
		png.Encode(stdin, dc.Image())
	}

	stdin.Close()
	return cmd.Wait()
}

```

### C. O Orquestrador (Paralelismo)

Arquivo: `internal/engine/orchestrator.go`

Coordena as goroutines e depois junta tudo de forma quase instantânea.

```go
package engine

import (
	"fmt"
	"os"
	"os/exec"
	"path/filepath"
	"sync"
	"videogen/internal/models"
)

func ProcessVideo(tmpl models.Template, finalOutput string) error {
	var wg sync.sync.WaitGroup
	tmpFiles := make([]string, len(tmpl.Cards))

	// 1. Renderiza os Cards em Paralelo
	for i, card := range tmpl.Cards {
		wg.Add(1)
		go func(i int, c models.Card) {
			defer wg.Done()
			
			// Nome do arquivo temp: tmp/card_01.ts
			outPath := filepath.Join("tmp", fmt.Sprintf("%s.ts", c.ID))
			tmpFiles[i] = outPath
			
			fmt.Printf("Começando renderização do card: %s...\n", c.ID)
			err := RenderCard(c, tmpl.Resolution, tmpl.FPS, outPath)
			if err != nil {
				fmt.Printf("Erro no card %s: %v\n", c.ID, err)
			}
		}(i, card)
	}

	wg.Wait()
	fmt.Println("Todos os cards renderizados! Juntando partes...")

	// 2. Concatenação (Juntar os arquivos .ts num único .mp4)
	return ConcatVideos(tmpFiles, finalOutput)
}

func ConcatVideos(files []string, finalOutput string) error {
	// Cria um arquivo txt "list.txt" para o FFmpeg
	listPath := "tmp/list.txt"
	f, _ := os.Create(listPath)
	for _, file := range files {
		f.WriteString(fmt.Sprintf("file '../%s'\n", file))
	}
	f.Close()

	// FFmpeg Concat Demuxer (Cópia direta sem re-renderizar, super rápido)
	cmd := exec.Command("ffmpeg", "-y", "-f", "concat", "-safe", "0", "-i", listPath, "-c", "copy", finalOutput)
	return cmd.Run()
}

```

### D. O Entrypoint do App

Arquivo: `cmd/videogen/main.go`

```go
package main

import (
	"encoding/json"
	"flag"
	"fmt"
	"log"
	"os"
	"videogen/internal/engine"
	"videogen/internal/models"
)

func main() {
	// Pega os argumentos do terminal
	jsonPath := flag.String("json", "templates/sample_v1.json", "Caminho do arquivo JSON de template")
	outPath := flag.String("out", "output_final.mp4", "Caminho e nome do arquivo de saída")
	flag.Parse()

	// Lê o arquivo JSON
	file, err := os.ReadFile(*jsonPath)
	if err != nil {
		log.Fatalf("Erro ao ler JSON: %v", err)
	}

	// Mapeia para a Struct
	var template models.Template
	if err := json.Unmarshal(file, &template); err != nil {
		log.Fatalf("Erro ao fazer parse do JSON: %v", err)
	}

	// Cria pasta tmp se não existir
	os.MkdirAll("tmp", os.ModePerm)

	// Inicia a orquestração
	fmt.Printf("Iniciando geração de vídeo (Template: %s)...\n", template.TemplateID)
	
	err = engine.ProcessVideo(template, *outPath)
	if err != nil {
		log.Fatalf("Falha crítica ao gerar vídeo: %v", err)
	}

	fmt.Printf("Vídeo gerado com sucesso: %s\n", *outPath)
}

```

